#Copy this file to terraform.tfvars and fill in your real values. terraform.tfvars is gitignored, so your real subscription ID never gets committed
subscription_id = "<your-azure-subscription-guid-here>"
location        = "eastus2"
admin_password  = "<12+ chars, upper & lower case, number, speshul symbol>" #this is fine for a lab, but real CI/CD pipeline work should never commit a password in cleartext on disk 